# Required
GEMINI_API_KEY=your-gemini-api-key

# Optional (for Solana wallet analysis features)
HELIUS_API_KEY=your-helius-api-key

# Optional (for Twitter API v2 - enables image uploads, higher rate limits)
# Without these, bots use cookie-based GraphQL auth only
# TWITTER_CONSUMER_KEY=
# TWITTER_CONSUMER_SECRET=
# TWITTER_ACCESS_TOKEN=
# TWITTER_ACCESS_SECRET=
